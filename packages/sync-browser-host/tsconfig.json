{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": "../..",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "orez/sync-browser-host": ["dist/sync-browser-host/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "test/browser/main.ts", "test/browser/worker.ts"]
}
