{
  "name": "on-zero",
  "version": "0.7.10",
  "description": "A typed layer over @rocicorp/zero with queries, mutations, and permissions",
  "sideEffects": false,
  "files": [
    "dist",
    "types",
    "src",
    "cli.cjs"
  ],
  "source": "src/index.ts",
  "main": "dist/cjs",
  "module": "dist/esm",
  "type": "module",
  "types": "./types/index.d.ts",
  "bin": {
    "on-zero": "./cli.cjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onejs/on-zero.git"
  },
  "homepage": "https://github.com/onejs/on-zero#readme",
  "bugs": {
    "url": "https://github.com/onejs/on-zero/issues"
  },
  "keywords": [
    "zero",
    "rocicorp",
    "sync",
    "mutations",
    "permissions",
    "react"
  ],
  "author": "Nate Wienert",
  "license": "MIT",
  "scripts": {
    "build": "tamagui-build",
    "watch": "tamagui-build --watch",
    "clean": "tamagui-build clean",
    "clean:build": "tamagui-build clean:build",
    "test": "vitest run && bun run test:consumer-types",
    "test:consumer-types": "bun run build && tsc -p test-fixtures/tsconfig.json",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --import-plugin",
    "lint:fix": "oxfmt && oxlint --import-plugin --fix --fix-suggestions"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "react-native": "./dist/esm/index.native.js",
      "types": "./types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./server": {
      "types": "./types/server.d.ts",
      "import": "./dist/esm/server.mjs"
    },
    "./vite": {
      "types": "./types/vite-plugin.d.ts",
      "import": "./dist/esm/vite-plugin.mjs",
      "require": "./dist/cjs/vite-plugin.cjs"
    },
    "./multi": {
      "react-native": "./dist/esm/multi.native.js",
      "types": "./types/multi.d.ts",
      "import": "./dist/esm/multi.mjs",
      "require": "./dist/cjs/multi.cjs"
    },
    "./drizzle": {
      "types": "./types/createSchemaFromDrizzle.d.ts",
      "import": "./dist/esm/createSchemaFromDrizzle.mjs",
      "require": "./dist/cjs/createSchemaFromDrizzle.cjs"
    },
    "./generate-lite": {
      "types": "./types/generate-lite.d.ts",
      "import": "./dist/esm/generate-lite.mjs",
      "require": "./dist/cjs/generate-lite.cjs"
    },
    "./generate": {
      "types": "./types/generate.d.ts",
      "import": "./dist/esm/generate.mjs",
      "require": "./dist/cjs/generate.cjs"
    }
  },
  "dependencies": {
    "@rocicorp/logger": "6.2.0",
    "chokidar": "^4.0.3",
    "citty": "^0.1.6",
    "dequal": "^2.0.3",
    "valibot": "^1.1.0"
  },
  "peerDependencies": {
    "@rocicorp/zero": ">=1.7.0",
    "drizzle-orm": ">=1.0.0-beta.0 <2",
    "drizzle-zero-sqlite": "^0.6.0",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "drizzle-zero-sqlite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tamagui/build": "2.3.1",
    "@types/node": "25.2.0",
    "@types/react": "^19.0.0",
    "jsdom": "29.1.1",
    "oxfmt": "^0.16.0",
    "oxlint": "^1.31.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "*",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  }
}
