{
  "name": "@orez/sync-cf-host",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/sync-wasm --target web --release --out-dir ../../packages/sync-cf-host/src/generated --out-name sync_wasm",
    "build:wasm:platform": "wasm-pack build ../../crates/sync-wasm --target web --release --out-dir ../../packages/sync-cf-host/src/generated --out-name sync_wasm -- --features platform-probes",
    "bundle": "bun run build:wasm && wrangler deploy --dry-run --outdir dist",
    "measure": "bun run build:wasm && bun measure.mjs",
    "test": "bun run test:config && bun run test:platform && bun run test:integration && bun run test:restart",
    "test:config": "bun test config.test.mjs",
    "test:integration": "bun run build:wasm && bun integration-test.mjs",
    "test:restart": "bun restart-test.mjs",
    "test:platform": "bun run build:wasm:platform && bun platform-test.mjs",
    "typecheck": "bun run build:wasm:platform && tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260617.1",
    "typescript": "5.9.3",
    "workerd": "1.20260617.1",
    "wrangler": "4.103.0"
  }
}
