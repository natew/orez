{
  "name": "drizzle-zero-sqlite",
  "version": "0.5.25",
  "description": "Generate Zero schemas from Drizzle SQLite schemas",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@rocicorp/zero": ">=1.5.0",
    "drizzle-orm": ">=1.0.0-beta.0 <2"
  },
  "devDependencies": {
    "@rocicorp/zero": "1.7.0",
    "drizzle-orm": "1.0.0-beta.9-e89174b",
    "oxfmt": "0.28.0",
    "oxlint": "1.43.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/natew/orez.git",
    "directory": "packages/drizzle-zero-sqlite"
  },
  "keywords": [
    "zero",
    "drizzle",
    "sqlite",
    "schema"
  ],
  "license": "MIT"
}
